<IfModule mod_php.c>
  php_value upload_max_filesize 10M
  php_value post_max_size 12M
  php_value max_execution_time 900
  php_value max_input_time 900
  php_value memory_limit 1024M
</IfModule>

<IfModule lsapi_module>
  php_value upload_max_filesize 10M
  php_value post_max_size 12M
  php_value max_execution_time 900
  php_value max_input_time 900
  php_value memory_limit 1024M
</IfModule>
